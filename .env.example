# Gmail API Credentials
# Copy this file to .env and fill in your values

# ============================================
# AUTHENTICATION METHOD 1: OAuth2 (Recommended for personal Gmail)
# ============================================
GMAIL_CLIENT_ID=828632338788-doerk5nonur32b17jud3k4o1vc77dtp6.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=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
GMAIL_REFRESH_TOKEN=

# ============================================
# AUTHENTICATION METHOD 2: Service Account (For Google Workspace)
# ============================================
SERVICE_ACCOUNT_KEY_FILE=
IMPERSONATE_EMAIL=

# ============================================
# System Configuration
# ============================================
AUTH_METHOD=oauth
POLL_INTERVAL_SECONDS=120
MAX_RETRIES=5

# Gmail query (default: unread primary tab emails)
GMAIL_QUERY=is:unread category:primary

# ============================================
# WhatsApp Configuration
# ============================================
ENABLE_WHATSAPP=false
WHATSAPP_HEADLESS=false
# Browser profile directory (persists login)
WHATSAPP_PROFILE=~/.whatsapp_fte_profile

# ============================================
# LinkedIn Configuration
# ============================================
ENABLE_LINKEDIN=false
LINKEDIN_HEADLESS=false
# Browser profile directory (persists login)
LINKEDIN_PROFILE=~/.linkedin_fte_profile

# ============================================
# Orchestrator Configuration
# ============================================
# Time for daily LinkedIn sales post generation (HH:MM)
DAILY_POST_TIME=09:00

# Operating Settings
TIMEZONE=UTC
ACTIVE_HOURS_START=00:00
ACTIVE_HOURS_END=23:59
WEEKEND_PROCESSING=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=AI_Employee_Vault/Logs/system.log
