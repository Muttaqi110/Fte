# Gmail API Credentials
# Copy this file to .env and fill in your values

# ============================================
# AUTHENTICATION METHOD 1: OAuth2 (Recommended for personal Gmail)
# ============================================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ============================================
# AUTHENTICATION METHOD 2: Service Account (For Google Workspace)
# ============================================
SERVICE_ACCOUNT_KEY_FILE=
IMPERSONATE_EMAIL=

# ============================================
# System Configuration
# ============================================
AUTH_METHOD=oauth
POLL_INTERVAL_SECONDS=120
MAX_RETRIES=5

# Gmail query (default: unread primary tab emails)
GMAIL_QUERY=is:unread category:primary

# ============================================
# WhatsApp Configuration
# ============================================
ENABLE_WHATSAPP=false
WHATSAPP_HEADLESS=false
# Browser profile directory (persists login)
WHATSAPP_PROFILE=~/.whatsapp_fte_profile

# ============================================
# LinkedIn Configuration
# ============================================
ENABLE_LINKEDIN=false
LINKEDIN_HEADLESS=false
# Browser profile directory (persists login)
LINKEDIN_PROFILE=~/.linkedin_fte_profile

# ============================================
# X (Twitter) Configuration
# ============================================
ENABLE_X=false
X_HEADLESS=false
# Browser profile directory (persists login)
X_PROFILE=~/.x_fte_profile

# ============================================
# Facebook Configuration
# ============================================
ENABLE_FACEBOOK=false
FACEBOOK_HEADLESS=false
# Browser profile directory (persists login)
FACEBOOK_PROFILE=~/.facebook_fte_profile

# ============================================
# Odoo Configuration (Gold Tier - Invoice Automation)
# ============================================
# SECURITY: Never hardcode credentials in code!
# Always read from these environment variables
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=
ODOO_API_VERSION=json-rpc
ODOO_TIMEOUT=30
ODOO_VERIFY_SSL=true

# Enable Odoo invoice automation
ENABLE_ODOO_INVOICING=false

# Enable Odoo vendor bill automation
ENABLE_ODOO_BILLS=false

# ============================================
# Orchestrator Configuration
# ============================================
# Time for daily LinkedIn sales post generation (HH:MM)
DAILY_POST_TIME=09:00

# Operating Settings
TIMEZONE=UTC
ACTIVE_HOURS_START=00:00
ACTIVE_HOURS_END=23:59
WEEKEND_PROCESSING=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=AI_Employee_Vault/Logs/system.log
